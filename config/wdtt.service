[Unit]
Description=WDTT — WireGuard over TURN Tunnel Server
Documentation=https://github.com/ZDarow/proxy-turn-vk-android
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/wdtt-start.sh
Restart=always
RestartSec=5
LimitNOFILE=65536
# Защита от fork-бомб (через cgroups)
TasksMax=2048
# Лимиты
MemoryMax=512M
CPUQuota=80%

[Install]
WantedBy=multi-user.target
